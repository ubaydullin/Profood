# Database configuration
# Leave empty to use SQLite by default
DATABASE_URL=sqlite+aiosqlite:///./salescrap.db
# Example for PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/salescrap

# Telegram Bot Configuration
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your personal Chat ID to receive alerts
# Get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=123456789

# Yandex Eda Authentication Cookie
# Extract the 'cookie:' header from Network tab
YANDEX_COOKIE="i=nZ0WB9uzEs...; sessionid2=..."

# Uzum Tezkor Authentication
# Extract 'cookie:' and 'authorization:' headers from Network tab
UZUM_COOKIE="lang=ru; tezkor_st=true; ..."
UZUM_AUTH_TOKEN="Bearer eyJhbGci..."
